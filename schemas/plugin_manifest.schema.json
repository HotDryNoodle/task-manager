{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mission-planer.local/schemas/plugin_manifest.schema.json",
  "title": "PluginManifest",
  "type": "object",
  "required": ["schema_version", "name", "executable", "version", "commands"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "name": { "type": "string", "minLength": 1 },
    "executable": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "domain": {
      "type": "string",
      "description": "Satellite subsystem domain, e.g. mission, image, telemetry"
    },
    "safety_class": {
      "type": "string",
      "enum": ["planning_only", "command_reversible", "command_irreversible"]
    },
    "commands": {
      "type": "array",
      "items": { "type": "string", "enum": ["manifest", "validate", "run"] },
      "minItems": 1
    },
    "scenarios": {
      "type": "array",
      "items": { "type": "string" }
    },
    "input_schema_path": { "type": "string" },
    "output_schema_path": { "type": "string" },
    "capabilities": {
      "type": "object",
      "properties": {
        "async": { "type": "boolean" },
        "dry_run": { "type": "boolean" },
        "cancel": { "type": "string", "enum": ["process_signal", "none"] },
        "requires_gmat": { "type": "boolean" },
        "requires_hardware": { "type": "boolean" },
        "batch": { "type": "boolean" },
        "idempotent": { "type": "boolean" }
      }
    },
    "resource_limits": {
      "type": "object",
      "properties": {
        "timeout_sec": { "type": "integer", "minimum": 1 },
        "max_parallel": { "type": "integer", "minimum": 1 },
        "max_work_dir_mb": { "type": "integer", "minimum": 1 }
      }
    },
    "agent_hints": {
      "type": "object",
      "properties": {
        "when_to_use": { "type": "string" },
        "prerequisites": {
          "type": "array",
          "items": { "type": "string" }
        },
        "typical_latency_sec": { "type": "integer", "minimum": 0 },
        "compose_with": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
